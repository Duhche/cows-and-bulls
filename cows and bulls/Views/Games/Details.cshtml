@{
    ViewData["Title"] = "Игра - Бикове и Крави";
}

<div class="container text-center mt-5" style="max-width: 550px; background: rgba(255, 255, 255, 0.95); padding: 35px; border-radius: 16px; box-shadow: 0 8px 24px rgba(0,0,0,0.25);">
    <h2 class="text-success fw-bold mb-2">🐂 БИКОВЕ И КРАВИ  Wait... 🐂</h2>
    <p class="text-muted">Разкодирай 4-цифреното тайно число (цифри от 0 до 7)</p>
    <hr />

    <div class="p-2 mb-3 bg-light rounded border">
        <h5 class="m-0 text-dark fw-bold">Направени опити: <span class="text-success">@ViewBag.Moves</span></h5>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger fw-bold shadow-sm">@TempData["Error"]</div>
    }

    @if (ViewBag.Win == true)
    {
        <div class="alert alert-success fw-bold fs-5 shadow-sm py-3 animate__animated animate__bounceIn">
            🎉 @TempData["Success"]
        </div>
        <a href="/" class="btn btn-primary btn-lg w-100 fw-bold mt-2 shadow-sm" style="border-radius: 10px;">Обратно към началното меню</a>
    }
    else
    {
        <form asp-action="PlayAction" method="post" autocomplete="off" class="mt-4">
            <div class="mb-3">
                <input type="text" name="userGuess" maxlength="4" placeholder="Въведи код тук (напр. 0123)" class="form-control text-center fw-bold shadow-sm" style="font-size: 1.6rem; letter-spacing: 6px; border-radius: 10px; border: 2px solid #198754;" required autofocus />
            </div>
            <button type="submit" class="btn btn-success btn-lg w-100 fw-bold py-2 shadow" style="border-radius: 10px;">Провери числото</button>
        </form>
    }

    @if (ViewBag.History != null && ((List<string>)ViewBag.History).Count > 0)
    {
        <h5 class="text-start fw-bold mt-4 mb-2 text-secondary">История на опитите:</h5>
        <div class="p-2 border rounded bg-white text-start shadow-inner style-scroll" style="max-height: 200px; overflow-y: auto;">
            @foreach (var move in (List<string>)ViewBag.History)
            {
                <div class="p-2 mb-1 border-bottom fw-bold text-dark" style="font-family: monospace; font-size: 1.05rem;">
                    @move
                </div>
            }
        </div>
    }
</div>