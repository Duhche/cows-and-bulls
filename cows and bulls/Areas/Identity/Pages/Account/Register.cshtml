@page "/Account/Register"
@model RegisterModel
@{
    ViewData["Title"] = "Регистрация";
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Регистрация - Cows and Bulls</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100% !important;
            margin: 0 !important;
        }

        body {
            /* Използваме директния път, тъй като видяхме, че файлът е в wwwroot */
            background-image: url('/grass_background.png') !important;
            background-color: #2d4d2a !important;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
            background-attachment: fixed !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .register-container {
            /* Прозрачен "стъъклен" ефект */
            background: rgba(255, 255, 255, 0.3) !important;
            backdrop-filter: blur(15px) !important;
            -webkit-backdrop-filter: blur(15px);
            padding: 40px !important;
            border-radius: 40px !important;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4) !important;
            width: 90% !important;
            max-width: 450px !important;
            text-align: center !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
        }

        h1 {
            color: #1e331c !important;
            font-weight: bold !important;
            margin-bottom: 10px !important;
        }

        p {
            color: #111 !important;
            margin-bottom: 25px !important;
            font-weight: 500;
        }

        .form-control {
            border-radius: 12px !important;
            margin-bottom: 10px !important;
            height: 45px !important;
            background: rgba(255, 255, 255, 0.7) !important;
            border: none !important;
        }

        .btn-green {
            background-color: #00a86b !important;
            color: white !important;
            border: none !important;
            width: 100% !important;
            padding: 12px !important;
            border-radius: 15px !important;
            font-weight: bold !important;
            font-size: 1.1rem !important;
            margin-top: 10px;
        }

            .btn-green:hover {
                background-color: #008f5d !important;
            }
    </style>
</head>
<body>

    <div class="register-container">
        <h1>Регистрация</h1>
        <p>Създай акаунт и започни да играеш!</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

            <div class="form-floating mb-2">
                <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                <label asp-for="Input.Email">Email</label>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Input.Password" type="password" class="form-control" autocomplete="new-password" placeholder="парола" />
                <label asp-for="Input.Password">Парола</label>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>

            <div class="form-floating mb-2">
                <input asp-for="Input.ConfirmPassword" type="password" class="form-control" autocomplete="new-password" placeholder="потвърди парола" />
                <label asp-for="Input.ConfirmPassword">Потвърди парола</label>
                <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
            </div>

            <button id="registerSubmit" type="submit" class="btn-green">Регистрирай ме</button>

            <div class="mt-3">
                <a asp-page="./Login" style="color: #0056b3; text-decoration: none; font-weight: bold;">Вече имаш акаунт? Влез тук</a>
            </div>
        </form>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <partial name="_ValidationScriptsPartial" />
</body>
</html>