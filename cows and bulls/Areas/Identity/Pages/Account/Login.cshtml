@page "/Account/Login"
@model LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход - Cows and Bulls</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        html, body {
            height: 100% !important;
            margin: 0 !important;
        }

        body {
            /* КОРЕКЦИЯ НА ПЪТЯ: Понеже картинката е директно в wwwroot */
            background-image: url('/grass_background.png') !important;
            background-color: #2d4d2a !important;
            background-size: cover !important;
            background-position: center !important;
            background-repeat: no-repeat !important;
            background-attachment: fixed !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .login-container {
            /* Прозрачен ефект (Glassmorphism) */
            background: rgba(255, 255, 255, 0.3) !important;
            backdrop-filter: blur(15px) !important;
            -webkit-backdrop-filter: blur(15px);
            padding: 50px 40px !important;
            border-radius: 40px !important;
            box-shadow: 0 20px 50px rgba(0,0,0,0.4) !important;
            width: 90% !important;
            max-width: 400px !important;
            text-align: center !important;
            border: 1px solid rgba(255, 255, 255, 0.2) !important;
        }

        h1 { color: #1e331c !important; font-weight: bold !important; margin-bottom: 20px !important; }

        .form-control {
            border-radius: 12px !important;
            margin-bottom: 15px !important;
            height: 50px !important;
            background: rgba(255, 255, 255, 0.7) !important;
            border: none !important;
        }

        .btn-green {
            background-color: #00a86b !important;
            color: white !important;
            border: none !important;
            width: 100% !important;
            padding: 12px !important;
            border-radius: 15px !important;
            font-weight: bold !important;
            font-size: 1.2rem !important;
        }
    </style>
</head>
<body>
    <div class="login-container">
        <h1>Cows and Bulls</h1>
        <p style="font-weight: 500;">Влез, за да започнеш играта!</p>
        <form id="account" method="post">
            <input asp-for="Input.Email" class="form-control" placeholder="Email" />
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Парола" />
            <div class="text-start mb-3">
                <input class="form-check-input" asp-for="Input.RememberMe" /> Запомни ме
            </div>
            <button type="submit" class="btn-green">Login</button>
            <div class="mt-3">
                <a asp-page="./Register" style="color: #0056b3; text-decoration: none; font-weight: bold;">Регистрация</a>
            </div>
        </form>
    </div>
</body>
</html>