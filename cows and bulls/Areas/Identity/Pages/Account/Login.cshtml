@page "/Account/Login"
@model LoginModel
@{
    ViewData["Title"] = "Вход";
    Layout = null;
}

<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Вход - Cows and Bulls</title>
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <style>
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background-image: url('https://img.freepik.com/free-vector/green-grass-vector-seamless-texture-lawn-nature-meadow-plant-field-natural-outdoor-illustration_1284-47056.jpg');
                background-repeat: repeat;
                margin: 0;
                height: 100vh;
                display: flex;
                align-items: center; 
                justify-content: center; 
            }

            .container-box {
                background: rgba(157, 192, 139, 0.95);
                padding: 40px;
                border-radius: 16px;
                max-width: 450px;
                width: 100%;
                box-shadow: 0 8px 20px rgba(0,0,0,0.25);
                color: #40513B;
                text-align: center;
            }

            h1 {
                margin-bottom: 10px;
            }

            p {
                margin-bottom: 25px;
            }

            .form-control {
                border-radius: 10px;
                margin-bottom: 15px;
                height: 45px;
                border: none;
            }

            .btn-green {
                background-color: #099966;
                color: #EDF1D6;
                border: none;
                width: 100%;
                padding: 12px;
                border-radius: 10px;
                font-weight: bold;
            }

                .btn-green:hover {
                    background-color: #40513B;
                }

            .register-link {
                margin-top: 15px;
            }

                .register-link a {
                    text-decoration: none;
                    color: #40513B;
                    font-weight: bold;
                }

                    .register-link a:hover {
                        text-decoration: underline;
                    }
                    .back-btn {
    margin-top: 20px;
}

.back-btn a {
    text-decoration: none;
    padding: 10px 18px;
    background-color: #099966;
    color: #EDF1D6;
    border-radius: 10px;
    font-weight: bold;
}

.back-btn a:hover {
    background-color: #40513B;
}
    </style>
</head>

<body>
    <div class="container-box">
        <h1>Cows and Bulls</h1>
        <p>Login to play</p>

        <form method="post">
            <input asp-for="Input.Email" class="form-control" placeholder="Email" />
            <input asp-for="Input.Password" type="password" class="form-control" placeholder="Password" />

            <button type="submit" class="btn-green">Login</button>

            <div class="register-link">
                <a asp-page="./Register">No account? Make one here.</a>
            </div>
        </form>
        <div class="back-btn">
            <a href="/">⬅ Back</a>
        </div>
    </div>
</body>
</html>